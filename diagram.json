{
  "version": 1,
  "author": "Vitória Maciel",
  "editor": "wokwi",
  "parts": [
    { "type": "board-esp32-devkit-c-v4", "id": "esp", "top": 0, "left": 0, "attrs": {} },
    { "type": "wokwi-lcd1602", "id": "lcd", "top": -220, "left": -10, "attrs": { "pins": "i2c" } },
    { "type": "wokwi-membrane-keypad", "id": "kp", "top": 0, "left": -310, "attrs": {} },
    { "type": "wokwi-servo", "id": "servo", "top": 70, "left": 280, "attrs": {} },
    { "type": "wokwi-led", "id": "led_g", "top": 220, "left": 180, "attrs": { "color": "green" } },
    { "type": "wokwi-resistor", "id": "r1", "top": 220, "left": 130, "rotate": 90, "attrs": { "value": "220" } },
    { "type": "wokwi-led", "id": "led_r", "top": 220, "left": 270, "attrs": { "color": "red" } },
    { "type": "wokwi-resistor", "id": "r2", "top": 220, "left": 220, "rotate": 90, "attrs": { "value": "220" } },
    { "type": "wokwi-buzzer", "id": "buz", "top": 290, "left": 180, "attrs": {} }
