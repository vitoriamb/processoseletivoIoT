    [ "esp:23", "r2:1", "yellow", [ "v100", "h0" ] ],
    [ "r2:2", "led_r:A", "yellow", [] ],
    [ "led_r:C", "esp:GND.3", "black", [ "v0", "h-100" ] ],

    [ "esp:5", "buz:1", "orange", [ "v150", "h0" ] ],
    [ "buz:2", "esp:GND.3", "black", [ "v0", "h-100" ] ]
