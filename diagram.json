  "connections": [
    [ "esp:TX", "$serialMonitor:RX", "", [] ],
    [ "esp:RX", "$serialMonitor:TX", "", [] ],

    [ "esp:3V3", "lcd:VCC", "red", [ "v-50", "h0" ] ],
    [ "esp:GND.2", "lcd:GND", "black", [ "v-60", "h0" ] ],
    [ "esp:21", "lcd:SDA", "green", [ "v-70", "h0" ] ],
    [ "esp:22", "lcd:SCL", "blue", [ "v-80", "h0" ] ],

    [ "esp:13", "kp:R1", "green", [ "h-40" ] ],
    [ "esp:12", "kp:R2", "green", [ "h-40" ] ],
    [ "esp:14", "kp:R3", "green", [ "h-40" ] ],
    [ "esp:27", "kp:R4", "green", [ "h-40" ] ],
    [ "esp:26", "kp:C1", "blue", [ "h-40" ] ],
    [ "esp:25", "kp:C2", "blue", [ "h-40" ] ],
    [ "esp:33", "kp:C3", "blue", [ "h-40" ] ],
    [ "esp:32", "kp:C4", "blue", [ "h-40" ] ],

    [ "esp:VIN", "servo:V+", "red", [ "h40" ] ],
